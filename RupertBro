-- Button 11: INVISIBLE
Button11.MouseButton1Click:Connect(function()
	-------------------------
	local char = LocalPlayer.Character
	if not char then
		statusText.Text = "No character found"
		return
	end
	if getgenv().InvisibleOn then
		getgenv().InvisibleOn = false
		for part, oldTrans in pairs(getgenv().OldTransparency or {}) do
			if part and part.Parent then
				part.Transparency = oldTrans
			end
		end
		getgenv().OldTransparency = nil
		-- Show face
		local head = char:FindFirstChild("Head")
		if head then
			local face = head:FindFirstChild("face")
			if face then face.Transparency = 0 end
		end
		-------------------------
		statusText.Text = "Invisible: OFF"
		return
	end
	getgenv().OldTransparency = {}
	for _, part in ipairs(char:GetDescendants()) do
		if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
			getgenv().OldTransparency[part] = part.Transparency
			part.Transparency = 1
		end
	end
	-- Hide face decal
	local head = char:FindFirstChild("Head")
	if head then
		local face = head:FindFirstChild("face")
		if face then
			getgenv().OldTransparency[face] = face.Transparency
			face.Transparency = 1
		end
	end
	getgenv().InvisibleOn = true
	-------------------------
	statusText.Text = "Invisible: ON"
end)
