	-- Function to refresh the tool list
	local function refreshTools()
		-- Clear existing entries
		for _, child in ipairs(toolScroll:GetChildren()) do
			if child:IsA("Frame") then
				child:Destroy()
			end
		end
		local allTools = getAllPlayerTools()
		local search = string.lower(searchBox.Text)
		local filtered = {}
		for _, data in ipairs(allTools) do
			if search == "" then
				table.insert(filtered, data)
			else
				if string.find(string.lower(data.player.Name), search, 1, true)
					or string.find(string.lower(data.player.DisplayName), search, 1, true)
					or string.find(string.lower(data.toolName), search, 1, true) then
					table.insert(filtered, data)
				end
			end
		end
		-- Count unique players with tools
		local playerSet = {}
		for _, data in ipairs(filtered) do
			playerSet[data.player.Name] = true
		end
		local playerCount = 0
		for _ in pairs(playerSet) do playerCount = playerCount + 1 end
		summaryLabel.Text = "Players with tools: " .. playerCount
		totalToolsLabel.Text = "Total tools: " .. #filtered
		-- Create entries
		for i, data in ipairs(filtered) do
			createToolEntry(data, i)
		end
		-- No tools message
		if #filtered == 0 then
			local noTools = Instance.new("TextLabel")
			noTools.Size = UDim2.new(1, 0, 0, 80)
			noTools.BackgroundTransparency = 1
			noTools.Text = "No tools found\nNo player is holding any tool right now"
			noTools.Font = Enum.Font.Gotham
			noTools.TextSize = 13
			noTools.TextColor3 = TEXT_SECONDARY
			noTools.LayoutOrder = 1
			noTools.Parent = toolScroll
		end
	end
	-- Refresh button click
	refreshBtn.MouseButton1Click:Connect(function()
		tw(refreshBtn, {BackgroundColor3 = ACCENT, TextColor3 = Color3.new(1,1,1)}, 0.08):Play()
		task.wait(0.08)
		tw(refreshBtn, {BackgroundColor3 = Color3.fromRGB(0, 60, 100), TextColor3 = ACCENT}, 0.3):Play()
		refreshTools()
	end)
	-- Search box change
	searchBox:GetPropertyChangedSignal("Text"):Connect(function()
		refreshTools()
	end)
	-- Minimize logic
	toolMini.MouseButton1Click:Connect(function()
		if not toolMinimized then
			toolMinimized = true
			toolMiniIcon.Text = "+"
