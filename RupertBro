	sliderTrack.BorderSizePixel = 0
	sliderTrack.Parent = content
	Instance.new("UICorner", sliderTrack).CornerRadius = UDim.new(1, 0)

	-- Speed slider fill
	local sliderFill = Instance.new("Frame")
	local fillRatio = math.clamp((flySpeed - 10) / 290, 0, 1)
	sliderFill.Size = UDim2.new(fillRatio, 0, 1, 0)
	sliderFill.BackgroundColor3 = ACCENT
	sliderFill.BorderSizePixel = 0
	sliderFill.Parent = sliderTrack
	Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)
	local sliderFillGrad = Instance.new("UIGradient")
	sliderFillGrad.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, ACCENT),
		ColorSequenceKeypoint.new(1, ACCENT_PURPLE)
	}
	sliderFillGrad.Parent = sliderFill

	-- Slider knob
	local sliderKnob = Instance.new("Frame")
	sliderKnob.Size = UDim2.new(0, 18, 0, 18)
	sliderKnob.Position = UDim2.new(fillRatio, -9, 0.5, -9)
	sliderKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	sliderKnob.BorderSizePixel = 0
	sliderKnob.ZIndex = 5
	sliderKnob.Parent = sliderTrack
	Instance.new("UICorner", sliderKnob).CornerRadius = UDim.new(1, 0)
	makeStroke(sliderKnob, ACCENT, 1.5)

	-- Slider interaction
	local dragging = false
	local function updateSlider(inputX)
		local relX = math.clamp((inputX - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
		flySpeed = math.floor(10 + relX * 290)
		sliderFill.Size = UDim2.new(relX, 0, 1, 0)
		sliderKnob.Position = UDim2.new(relX, -9, 0.5, -9)
		speedValue.Text = tostring(flySpeed)
	end

	sliderTrack.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateSlider(input.Position.X)
		end
	end)
	sliderTrack.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateSlider(input.Position.X)
		end
	end)

	-- Speed presets
	local presetsFrame = Instance.new("Frame")
	presetsFrame.Size = UDim2.new(1, -24, 0, 34)
	presetsFrame.Position = UDim2.new(0, 12, 0, 172)
	presetsFrame.BackgroundTransparency = 1
	presetsFrame.Parent = content
