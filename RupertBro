	local btnGrad = Instance.new("UIGradient")
	btnGrad.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(18, 18, 30)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(12, 12, 20))
	}
	btnGrad.Rotation = 90
	btnGrad.Parent = btn
	-- Left accent strip (visible when selected)
	local selStrip = Instance.new("Frame")
	selStrip.Size = UDim2.new(0, 3, 0.55, 0)
	selStrip.Position = UDim2.new(0, 0, 0.225, 0)
	selStrip.BackgroundColor3 = ACCENT
	selStrip.BorderSizePixel = 0
	selStrip.BackgroundTransparency = 1
	selStrip.ZIndex = 2
	selStrip.Parent = btn
	Instance.new("UICorner", selStrip).CornerRadius = UDim.new(0, 2)
	local selStripGrad = Instance.new("UIGradient")
	selStripGrad.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, ACCENT),
		ColorSequenceKeypoint.new(1, ACCENT_PURPLE)
	}
	selStripGrad.Rotation = 90
	selStripGrad.Parent = selStrip
	-- Name label
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size = UDim2.new(1, -34, 1, 0)
	nameLabel.Position = UDim2.new(0, 32, 0, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = name
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextSize = 11
	nameLabel.TextColor3 = TEXT_SECONDARY
	nameLabel.Parent = btn
	-- Content frame for this category's buttons
	local catContent = Instance.new("Frame")
	catContent.Size = UDim2.new(1, 0, 0, 0)
	catContent.BackgroundTransparency = 1
	catContent.Visible = false
	catContent.Parent = contentArea
	local catLayout = Instance.new("UIListLayout")
	catLayout.Padding = UDim.new(0, 4)
	catLayout.SortOrder = Enum.SortOrder.LayoutOrder
	catLayout.Parent = catContent
	catLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		catContent.Size = UDim2.new(1, 0, 0, catLayout.AbsoluteContentSize.Y)
		-- Update parent scrolling frame canvas
		contentArea.CanvasSize = UDim2.new(0, 0, 0, contentArea.UIListLayout and contentArea.UIListLayout.AbsoluteContentSize.Y + 10 or 0)
	end)
	local catData = {
		button = btn,
		content = catContent,
		name = nameLabel,
		strip = selStrip,
	}
	table.insert(categories, catData)
	local function selectCat()
		for _, cat in ipairs(categories) do
			cat.content.Visible = false
			tw(cat.button, {BackgroundColor3 = BG_CARD}, 0.2):Play()
			tw(cat.name, {TextColor3 = TEXT_SECONDARY}, 0.2):Play()
			tw(cat.strip, {BackgroundTransparency = 1}, 0.2):Play()
		end
		catContent.Visible = true
		tw(btn, {BackgroundColor3 = BG_HOVER}, 0.2):Play()
		tw(nameLabel, {TextColor3 = TEXT_PRIMARY}, 0.2):Play()
		tw(selStrip, {BackgroundTransparency = 0}, 0.2):Play()
		selectedCategory = catData
	end
	catData.select = selectCat
	btn.MouseButton1Click:Connect(selectCat)
	btn.MouseEnter:Connect(function()
		if selectedCategory ~= catData then
			tw(btn, {BackgroundColor3 = BG_HOVER}, 0.15):Play()
			tw(nameLabel, {TextColor3 = TEXT_PRIMARY}, 0.15):Play()
		end
	end)
	btn.MouseLeave:Connect(function()
		if selectedCategory ~= catData then
			tw(btn, {BackgroundColor3 = BG_CARD}, 0.15):Play()
			tw(nameLabel, {TextColor3 = TEXT_SECONDARY}, 0.15):Play()
		end
	end)
	return catContent
end
