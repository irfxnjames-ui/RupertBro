-- Key verification function
local function verifyKey()
	local input = keyInput.Text
	if input == CORRECT_KEY then
		-- Success animation
		keyError.Text = ""
		tw(keySubmit, {BackgroundColor3 = SUCCESS, TextColor3 = Color3.new(1,1,1)}, 0.15):Play()
		keySubmit.Text = "✓ UNLOCKED"
		task.wait(0.5)
		-- Animate key card out
		tw(keyCard, {Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)}, 0.3, Enum.EasingStyle.Back):Play()
		tw(keyOverlay, {BackgroundTransparency = 1}, 0.4):Play()
		task.wait(0.4)
		keyGui:Destroy()
		-- Trigger intro animation
		playIntro()
	else
		-- Wrong key - shake animation
		keyError.Text = "Invalid key. Try again."
		tw(keyInput, {BackgroundColor3 = Color3.fromRGB(60, 15, 20)}, 0.1):Play()
		local baseX = -keyCardW/2
		local baseY = -keyCardH/2
		tw(keyCard, {Position = UDim2.new(0.5, baseX - 8, 0.5, baseY)}, 0.05):Play()
		task.wait(0.05)
		tw(keyCard, {Position = UDim2.new(0.5, baseX + 8, 0.5, baseY)}, 0.05):Play()
		task.wait(0.05)
		tw(keyCard, {Position = UDim2.new(0.5, baseX - 4, 0.5, baseY)}, 0.05):Play()
		task.wait(0.05)
		tw(keyCard, {Position = UDim2.new(0.5, baseX + 4, 0.5, baseY)}, 0.05):Play()
		task.wait(0.05)
		tw(keyCard, {Position = UDim2.new(0.5, baseX, 0.5, baseY)}, 0.1):Play()
		tw(keyInput, {BackgroundColor3 = Color3.fromRGB(14, 14, 24)}, 0.3):Play()
		task.wait(1.5)
		keyError.Text = ""
	end
end

keySubmit.MouseButton1Click:Connect(verifyKey)
keyInput.FocusLost:Connect(function(enterPressed)
	if enterPressed then
