	presetsLayout.Padding = UDim.new(0, 6)
	presetsLayout.SortOrder = Enum.SortOrder.LayoutOrder
	presetsLayout.Parent = presetsFrame

	local presets = {{"Slow", 30}, {"Normal", 50}, {"Fast", 100}, {"Insane", 200}, {"Max", 300}}
	for i, preset in ipairs(presets) do
		local pBtn = Instance.new("TextButton")
		pBtn.Size = UDim2.new(0, 54, 0, 30)
		pBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 45)
		pBtn.BorderSizePixel = 0
		pBtn.Text = preset[1]
		pBtn.Font = Enum.Font.GothamBold
		pBtn.TextSize = 10
		pBtn.TextColor3 = flySpeed == preset[2] and ACCENT or Color3.fromRGB(160, 160, 190)
		pBtn.AutoButtonColor = false
		pBtn.LayoutOrder = i
		pBtn.Parent = presetsFrame
		Instance.new("UICorner", pBtn).CornerRadius = UDim.new(0, 8)
		makeStroke(pBtn, flySpeed == preset[2] and ACCENT or Color3.fromRGB(40, 40, 70), 0.5)

		pBtn.MouseButton1Click:Connect(function()
			flySpeed = preset[2]
			local r = math.clamp((flySpeed - 10) / 290, 0, 1)
			sliderFill.Size = UDim2.new(r, 0, 1, 0)
			sliderKnob.Position = UDim2.new(r, -9, 0.5, -9)
			speedValue.Text = tostring(flySpeed)
			-- Update preset button highlights
			for _, btn in ipairs(presetsFrame:GetChildren()) do
				if btn:IsA("TextButton") then
					local _, s = pcall(function() return btn.Text end)
					btn.TextColor3 = Color3.fromRGB(160, 160, 190)
					makeStroke(btn, Color3.fromRGB(40, 40, 70), 0.5)
				end
			end
			pBtn.TextColor3 = ACCENT
			makeStroke(pBtn, ACCENT, 0.5)
		end)

		pBtn.MouseEnter:Connect(function()
			tw(pBtn, {BackgroundColor3 = Color3.fromRGB(35, 35, 60)}, 0.15):Play()
		end)
		pBtn.MouseLeave:Connect(function()
			tw(pBtn, {BackgroundColor3 = Color3.fromRGB(25, 25, 45)}, 0.15):Play()
		end)
	end

	-- Controls hint
	local hintLabel = Instance.new("TextLabel")
	hintLabel.Size = UDim2.new(1, -24, 0, 30)
	hintLabel.Position = UDim2.new(0, 12, 1, -38)
	hintLabel.BackgroundTransparency = 1
	hintLabel.Text = "WASD: Move  |  Space: Up  |  Shift: Down"
	hintLabel.Font = Enum.Font.Gotham
	hintLabel.TextSize = 10
	hintLabel.TextColor3 = Color3.fromRGB(100, 100, 130)
	hintLabel.Parent = content

	statusText.Text = "Fly Noclip GUI opened"
end)
