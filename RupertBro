-- Utility: Add UICorner
local function makeCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 10)
	c.Parent = parent
	return c
end
-- Utility: Create Gradient
local function makeGradient(parent, c1, c2, rot)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, c1 or Color3.fromRGB(20, 20, 35)),
		ColorSequenceKeypoint.new(1, c2 or Color3.fromRGB(8, 8, 16))
	}
	g.Rotation = rot or 90
	g.Parent = parent
	return g
end
-- Utility: Create Stroke
local function makeStroke(parent, color, thickness)
	local s = Instance.new("UIStroke")
	s.Color = color or Color3.fromRGB(40, 40, 70)
	s.Thickness = thickness or 1
	s.Transparency = 0.1
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = parent
	return s
end
-- Utility: Tween Helper
local function tw(instance, props, duration, style)
	return TweenService:Create(
		instance,
		TweenInfo.new(
			duration or 0.2,
			style or Enum.EasingStyle.Quart,
			Enum.EasingDirection.Out
		),
		props
	)
end
-- Drag system
local function Drag(guiObject)
	local dragging = false
	local dragStart, startPos, dragInput
	guiObject.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = guiObject.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	guiObject.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	UIS.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			guiObject.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)
end
