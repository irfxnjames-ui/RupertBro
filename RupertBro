			toolMiniIcon.Text = "−"
			tw(toolFrame, {Size = UDim2.new(0, 380, 0, 480)}, 0.25):Play()
			task.wait(0.25)
			summaryInfo.Visible = true
			searchBox.Visible = true
			refreshBtn.Visible = true
			toolScroll.Visible = true
		end
	end)
	-- Close button
	toolClose.MouseButton1Click:Connect(function()
		local closeTween = tw(toolFrame, {Size = UDim2.new(0, 0, 0, 0), Position = toolFrame.Position + UDim2.new(0, 190, 0, 240)}, 0.3, Enum.EasingStyle.Back)
